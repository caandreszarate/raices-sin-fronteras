# ============================================================================
# Raíces sin Fronteras — Variables de entorno (plantilla)
# Copia este archivo a `.env.local` y rellena los valores.
# NUNCA subas `.env.local` al repositorio. NUNCA expongas claves al cliente:
# solo las variables con prefijo NEXT_PUBLIC_ llegan al navegador.
# ============================================================================

# URL pública del sitio (usada en SEO, sitemap, canónicas y metadatos).
NEXT_PUBLIC_SITE_URL=https://raicessinfronteras.org

# --- Formulario de contacto / boletín (correo) -------------------------------
# Proveedor de email transaccional (ej. Resend). Solo servidor.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=hola@raicessinfronteras.org
# CONTACT_FROM_EMAIL=web@raicessinfronteras.org

# --- Base de datos / CMS (opcional) ------------------------------------------
# Para persistir mensajes, suscriptores, proyectos, noticias y galería.
# DATABASE_URL=postgresql://usuario:password@host:5432/raices
# Supabase (si se usa):
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=     # SOLO servidor, nunca en cliente

# --- Pasarela de pagos / donaciones (opcional) -------------------------------
# Solo servidor. El endpoint /api/donaciones/checkout las usa.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=   # clave pública (sí puede ir al cliente)

# --- Rate limiting distribuido (opcional, producción multi-instancia) --------
# Por defecto se usa un limitador en memoria (suficiente para una instancia).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
